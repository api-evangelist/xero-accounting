          "http": {
            "method": "GET",
            "url": "https://api.xero.com/api.xro/2.0/BankTransactions/:BankTransactionID",
            "headers": [
              {
                "name": "Xero-Tenant-Id",
                "value": ""
              }
            ],
            "params": [
              {
                "name": "BankTransactionID",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieve a single spent or received money transaction"
        }
      ]
    },
    {
      "info": {
        "name": "BankTransfers",
        "type": "folder"
      },
      "items": [
