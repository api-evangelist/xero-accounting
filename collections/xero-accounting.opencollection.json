          "http": {
            "method": "PUT",
            "url": "https://api.xero.com/api.xro/2.0/BankTransfers",
            "headers": [
              {
                "name": "Xero-Tenant-Id",
                "value": ""
              }
            ]
          },
          "docs": "Create a bank transfer"
        }
      ]
    },
    {
      "info": {
        "name": "BatchPayments",
        "type": "folder"
