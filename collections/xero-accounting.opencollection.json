            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.xero.com/api.xro/2.0/Contacts",
            "headers": [
              {
                "name": "Xero-Tenant-Id",
                "value": ""
              }
            ]
          },
