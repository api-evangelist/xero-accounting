            "name": "Retrieve all bank transfers",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.xero.com/api.xro/2.0/BankTransfers",
            "headers": [
              {
                "name": "Xero-Tenant-Id",
                "value": ""
              }
            ]
